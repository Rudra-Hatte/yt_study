# ==============================================
# DATABASE CONFIGURATION
# ==============================================
# MongoDB connection string (use MongoDB Atlas for production)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/yt-study?retryWrites=true&w=majority

# ==============================================
# AUTHENTICATION & SECURITY
# ==============================================
# JWT Secret for token signing (generate a strong random string)
JWT_SECRET=your-super-secure-jwt-secret-key-here

# ==============================================
# AI & EXTERNAL SERVICES
# ==============================================
# AI features are proxied via ai-service (Groq + RAG)
# Keep AI_SERVICE_URL pointing to your ai-service deployment/local instance

# AI Service URL (URL of your deployed AI service)
AI_SERVICE_URL=http://localhost:5001/api/ai

# ==============================================
# FRONTEND CONFIGURATION
# ==============================================
# Frontend URL for CORS (your Vercel deployment URL)
FRONTEND_URL=https://your-frontend.vercel.app

# ==============================================
# SERVER CONFIGURATION
# ==============================================
# Backend server port
PORT=5000

# Environment mode
NODE_ENV=production