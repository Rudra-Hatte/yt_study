# ==============================================
# AI SERVICE CONFIGURATION WITH KEY ROTATION
# ==============================================

# Primary model provider keys (required)
# Add up to 4 keys for rotation
PRIMARY_API_KEY_1=your-primary-api-key-1
PRIMARY_API_KEY_2=your-primary-api-key-2
PRIMARY_API_KEY_3=your-primary-api-key-3
PRIMARY_API_KEY_4=
PRIMARY_API_KEY=

# Backup model provider keys (optional, fallback only)
BACKUP_API_KEY_1=
BACKUP_API_KEY_2=
BACKUP_API_KEY_3=
BACKUP_API_KEY_4=
BACKUP_API_KEY=

# Model configuration
PRIMARY_MODEL=llama-3.3-70b-versatile
BACKUP_MODEL=backup-model-id

# Fine-tuned model metadata (exists, but live queries still use API keys)
FINETUNED_MODEL_ID=your-finetuned-model-id
FINETUNED_MODEL_EXISTS=true

# MongoDB connection string used for RAG knowledge storage
MONGODB_URI=mongodb+srv://<db_user>:<db_password>@<cluster-host>/<db_name>?retryWrites=true&w=majority

# RAG controls
RAG_ENABLED=true
RAG_TOP_K=6
RAG_MIN_SCORE=0.04
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=200

# YouTube Data API v3 Keys (Required) - Add 4 keys for rotation to avoid rate limits
# Get them from: https://console.developers.google.com
YOUTUBE_API_KEY_1=your-youtube-api-key-1
YOUTUBE_API_KEY_2=your-youtube-api-key-2-here
YOUTUBE_API_KEY_3=your-youtube-api-key-3-here
YOUTUBE_API_KEY_4=your-youtube-api-key-4-here

# ==============================================
# CORS CONFIGURATION
# ==============================================
# Frontend URL for CORS (your Vercel deployment URL)
FRONTEND_URL=https://your-frontend.vercel.app
# Backend URL for CORS (your Render backend URL)
BACKEND_URL=https://your-backend.onrender.com

# ==============================================
# SERVER CONFIGURATION
# ==============================================
PORT=5001

# ==============================================
# NOTES
# ==============================================
# - Recommended setup: 3 primary keys + 1 YouTube key + MongoDB URI
# - System will automatically rotate between available keys
# - If a key hits rate limit, it will be temporarily skipped
# - Live queries use API keys. Fine-tuned model is metadata-only in this setup.
